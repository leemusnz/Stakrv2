{
  "name": "stakr-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0",
    "pnpm": ">=8.0.0"
  },
  "overrides": {
    "preact": "^10.29.0",
    "cookie": "^0.7.2",
    "esbuild": "^0.25.8",
    "@smithy/config-resolver": "^4.4.0"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "format": "prettier --write .",
    "lint": "next lint",
    "start": "next start",
    "test": "jest",
    "test:all": "node scripts/run-tests.js",
    "test:components": "jest --testPathPattern=\"components|app\" --testEnvironment=jsdom",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:points": "playwright test tests/e2e/points/",
    "test:e2e:cash": "playwright test tests/e2e/cash/",
    "test:e2e:integration": "playwright test tests/e2e/integration/",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:integration": "jest --testPathPattern=\"integration|api-endpoints|auth|avatar-system|challenge-system\"",
    "test:report": "jest --coverage --json --outputFile=test-reports/coverage.json",
    "test:unit": "jest --testPathPattern=\"unit|utils|helpers\"",
    "test:watch": "jest --watch",
    "test:mobile": "node scripts/mobile-test.js",
    "lighthouse:mobile": "lighthouse https://stakr.app --preset=mobile --view",
    "lighthouse:desktop": "lighthouse https://stakr.app --preset=desktop --view",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@aws-sdk/client-rds-data": "latest",
    "@aws-sdk/client-rekognition": "latest",
    "@aws-sdk/client-s3": "latest",
    "@aws-sdk/s3-request-presigner": "latest",
    "@cloudflare/workers-types": "latest",
    "@hookform/resolvers": "^3.9.1",
    "@jest/globals": "latest",
    "@neondatabase/serverless": "latest",
    "@opentelemetry/api": "latest",
    "@radix-ui/react-accordion": "latest",
    "@radix-ui/react-alert-dialog": "latest",
    "@radix-ui/react-aspect-ratio": "latest",
    "@radix-ui/react-avatar": "latest",
    "@radix-ui/react-checkbox": "latest",
    "@radix-ui/react-collapsible": "latest",
    "@radix-ui/react-context-menu": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-dropdown-menu": "latest",
    "@radix-ui/react-hover-card": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-menubar": "latest",
    "@radix-ui/react-navigation-menu": "latest",
    "@radix-ui/react-popover": "latest",
    "@radix-ui/react-progress": "latest",
    "@radix-ui/react-radio-group": "latest",
    "@radix-ui/react-scroll-area": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "latest",
    "@radix-ui/react-slider": "latest",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-switch": "latest",
    "@radix-ui/react-tabs": "latest",
    "@radix-ui/react-toast": "latest",
    "@radix-ui/react-toggle": "latest",
    "@radix-ui/react-toggle-group": "latest",
    "@radix-ui/react-tooltip": "latest",
    "@react-email/render": "latest",
    "@sentry/nextjs": "^10.48.0",
    "@testing-library/dom": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@upstash/redis": "latest",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "latest",
    "browser-image-compression": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "latest",
    "date-fns": "latest",
    "dotenv": "^17.2.3",
    "drizzle-kit": "latest",
    "drizzle-orm": "latest",
    "embla-carousel-react": "latest",
    "framer-motion": "^12.23.12",
    "input-otp": "latest",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "next": "15.5.12",
    "next-auth": "latest",
    "next-themes": "latest",
    "nodemailer": "latest",
    "react": "^19",
    "react-day-picker": "latest",
    "react-dom": "^19",
    "react-hook-form": "latest",
    "react-resizable-panels": "latest",
    "recharts": "latest",
    "resend": "latest",
    "sonner": "latest",
    "stripe": "^20.0.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lighthouse": "^13.0.3",
    "lint-staged": "^15.2.11",
    "postcss": "^8.5",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
